{
  "name": "newick-viewer",
  "version": "1.0.0",
  "description": "Interactive phylogenetic tree viewer for Newick format files",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/d3": "^7.4.3",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "lz-string": "^1.5.0"
  }
}
